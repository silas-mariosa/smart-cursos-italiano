# PostgreSQL connection string
DB_CONNECTION=postgresql://user:password@localhost:5432/app_template

# Server
PORT=4000
NODE_ENV=development

# JWT — obrigatório em produção (nunca commitar valor real)
JWT_SECRET=change-me-in-production

# CORS — origens separadas por vírgula; * para desenvolvimento
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
